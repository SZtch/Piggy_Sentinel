# ─────────────────────────────────────────────────────────────────────────────
# PiggySentinel — Environment Variables
# Copy file ini ke .env dan isi semua nilai sebelum deploy
# ─────────────────────────────────────────────────────────────────────────────

# ── App Environment ───────────────────────────────────────────────────────────
APP_ENV=prod
NODE_ENV=production
ENABLE_MAINNET_EXECUTION=true

# ── RPC URLs ──────────────────────────────────────────────────────────────────
CELO_RPC_URL_MAINNET=https://forno.celo.org 

# ── Agent Wallet ──────────────────────────────────────────────────────────────
AGENT_SIGNER_PRIVATE_KEY=0x_GANTI_DENGAN_PRIVATE_KEY_AGENT
AGENT_SIGNER_ADDRESS=0x_GANTI_DENGAN_ADDRESS_AGENT

# ── Treasury ──────────────────────────────────────────────────────────────────
TREASURY_ADDRESS=0x_GANTI_DENGAN_ADDRESS_TREASURY

# ── Deployed Contract Addresses (isi setelah forge deploy) ───────────────────
SENTINEL_EXECUTOR_ADDRESS=0x_ISI_SETELAH_DEPLOY
AAVE_ADAPTER_ADDRESS=0x_ISI_SETELAH_DEPLOY
MENTO_ADAPTER_ADDRESS=0x_ISI_SETELAH_DEPLOY
UNISWAP_ADAPTER_ADDRESS=0x_ISI_SETELAH_DEPLOY
AAVE_ORACLE_WRAPPER_ADDRESS=0x_ISI_SETELAH_DEPLOY

# ── Aave aToken Addresses (Celo Mainnet — sudah confirmed) ───────────────────
A_USDC_ADDRESS=0xFF8309b9e99bfd2D4021bc71a362aBD93dBd4785
A_USDT_ADDRESS=0xDeE98402A302e4D707fB9bf2bac66fAEEc31e8Df
A_USDM_ADDRESS=0xBba98352628B0B0c4b40583F593fFCb630935a45

# ── Uniswap Pool (untuk baca ETH price) ──────────────────────────────────────
UNISWAP_USDC_WETH_POOL=0x2d70Cbabf4D8e61d5317B62cBF8C90B342b7d2e2

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/piggysentinel

# ── Gas Config ────────────────────────────────────────────────────────────────
MAX_GAS_PRICE_GWEI=50
MAX_GAS_COST_USD=0.50
TYPICAL_REBALANCE_GAS=300000
MAX_GAS_PER_TX=800000

# ── APY Fallback ──────────────────────────────────────────────────────────────
APY_USDM=1.07
APY_USDC=2.61
APY_USDT=8.89

# ── ETH Price Fallback ────────────────────────────────────────────────────────
ETH_PRICE_USD=3000

# ── Circuit Breaker ───────────────────────────────────────────────────────────
CIRCUIT_BREAKER_VOLATILITY_PCT=15.0

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=_GANTI_DENGAN_BOT_TOKEN

# ── Deploy only ───────────────────────────────────────────────────────────────
DEPLOYER_ADDRESS=0x_GANTI_DENGAN_ADDRESS_DEPLOYER

# ── Strategy ─────────────────────────────────────────────────────────────────
USE_OPENCLAW_STRATEGY=false

# ── Frontend Token + aToken Addresses ────────────────────────────────────────
# Used by the withdraw page to read Aave positions and call SentinelExecutor.withdraw()
NEXT_PUBLIC_SENTINEL_EXECUTOR_ADDRESS=0x_ISI_SETELAH_DEPLOY
NEXT_PUBLIC_USDM_ADDRESS=0x765DE816845861e75A25fCA122bb6898B8B1282a
NEXT_PUBLIC_USDC_ADDRESS=0xcebA9300f2b948710d2653dD7B07f33A8B32118C
NEXT_PUBLIC_USDT_ADDRESS=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e
NEXT_PUBLIC_A_USDC_ADDRESS=0xFF8309b9e99bfd2D4021bc71a362aBD93dBd4785
NEXT_PUBLIC_A_USDT_ADDRESS=0xDeE98402A302e4D707fB9bf2bac66fAEEc31e8Df
NEXT_PUBLIC_A_USDM_ADDRESS=0xBba98352628B0B0c4b40583F593fFCb630935a45

# ── API & Frontend ────────────────────────────────────────────────────────────
PIGGY_API_URL=https://api.yourdomain.com        # Backend API URL
NEXT_PUBLIC_API_URL=https://api.yourdomain.com  # Same, for Next.js
NEXT_PUBLIC_APP_ENV=prod                         # "prod" untuk mainnet
NEXT_PUBLIC_PRIVY_APP_ID=clx_GANTI_PRIVY_APP_ID
NEXT_PUBLIC_TELEGRAM_BOT_URL=https://t.me/PiggySentinelBot

# ── Privy (auth) ──────────────────────────────────────────────────────────────
# PRIVY_APP_ID     = same as NEXT_PUBLIC_PRIVY_APP_ID
# PRIVY_APP_SECRET = from Privy dashboard → Settings → API Keys (keep secret, backend only)
PRIVY_APP_ID=clx_GANTI_PRIVY_APP_ID
PRIVY_APP_SECRET=_GANTI_DENGAN_PRIVY_APP_SECRET

# ── Internal API secret (scheduler → API communication) ──────────────────────
# Generate: openssl rand -hex 32
# The scheduler sends this in x-internal-secret header to access /api/goals/all-active
INTERNAL_API_SECRET=_GANTI_DENGAN_SECRET_32_CHARS_MIN

# ── AI ────────────────────────────────────────────────────────────────────────
CLAUDE_API_KEY=sk-ant-GANTI_DENGAN_API_KEY

# ── Redis (BullMQ) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Security ─────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Protocol Addresses (Celo Mainnet) ────────────────────────────────────────
AAVE_POOL_ADDRESS=0x3E59A31363E2ad014dcbc521c4a0d5757d9f3402
UNISWAP_PM_ADDRESS=0x3d2bD0e15829AA5C362a4144FdF4A1112fa29B5c
